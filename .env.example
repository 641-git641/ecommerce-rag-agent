# ============================================================
# 电商 RAG 系统 — Docker 环境变量
# 复制此文件为 .env 并填入真实值后 docker-compose up -d
# ============================================================

# ── 通义千问 API Key (必填) ─────────────────────────────
# 获取地址: https://dashscope.aliyun.com/
OPENAI_API_KEY=sk-your-api-key-here

# ── 模型配置 (可选，默认值如下) ──────────────────────────
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-turbo

# ── MySQL 配置 (可选) ────────────────────────────────────
MYSQL_ROOT_PASSWORD=root123

# ── Go 服务配置 (可选) ───────────────────────────────────
# GIN_MODE=release
# SERVER_PORT=:8080

# ── 端口映射 (可选，修改默认端口避免冲突) ────────────────
# 前端/API 网关: 8080
# Python RAG 服务: 9000
# MySQL: 3307 (宿主机) -> 3306 (容器)
# Redis: 6380 (宿主机) -> 6379 (容器)
